# Copy this file to ../.env.kepler for local runs.
# Kepler does not parse dotenv files itself; `scripts/run-kepler.sh` sources
# `./.env.kepler` before launching the service.

# Required: Linear runtime auth (preferred)
LINEAR_CLIENT_ID=lin_oauth_client_id
LINEAR_CLIENT_SECRET=lin_oauth_client_secret

# Required: Linear webhook signing secret
LINEAR_WEBHOOK_SECRET=lin_webhook_secret

# Optional fallback only: personal/workspace API key for staging or migration
# LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxx

# Required writable paths for repository workspaces and durable state
KEPLER_WORKSPACE_ROOT=$HOME/.kepler/workspaces
KEPLER_STATE_ROOT=$HOME/.kepler/state

# Optional but recommended if you want to expose /api/v1/kepler/runs
KEPLER_API_TOKEN=replace-with-a-long-random-token

# Required if you use the bundled fallback workflow unchanged.
# If every repo supplies its own workflow with an explicit Codex command,
# you can omit this and rely on that repo-local command instead.
CODEX_BIN=codex

# Required for unattended Codex auth on fresh hosts and containers.
# Example startup path:
#   printenv OPENAI_API_KEY | codex login --with-api-key
OPENAI_API_KEY=sk-...

# Preferred GitHub auth: GitHub App credentials
# Railway/Docker path:
# 1. Generate a private key in the GitHub App settings UI.
# 2. Convert the downloaded PEM to base64 on your machine.
# 3. Paste that single-line value into GITHUB_APP_PRIVATE_KEY_BASE64.
# The shipped container entrypoint will decode it into GITHUB_APP_PRIVATE_KEY.
GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----..."
# GITHUB_APP_PRIVATE_KEY_BASE64=LS0tLS1CRUdJTiBQUklWQVRFIEtFWS0tLS0t...
# VM/local fallback only:
# GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/kepler-github-app.pem

# Optional fallback only: personal access token with clone/push/PR access
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
